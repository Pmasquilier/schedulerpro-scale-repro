{
  "name": "schedulerpro-scale-repro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Reproduction comparing two data-loading strategies for Bryntum Scheduler Pro at scale (lazy vs non-lazy) with a custom non-CrudManager backend.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@bryntum/scheduler": "npm:@bryntum/scheduler-trial@7.3.1",
    "@bryntum/scheduler-react": "7.3.2",
    "@bryntum/schedulerpro": "npm:@bryntum/schedulerpro-trial@7.3.1",
    "@bryntum/schedulerpro-react": "7.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "msw": "^2.14.6",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}